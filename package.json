{
  "name": "@francav/components",
  "version": "0.1.5",
  "description": "DPG L3 governance Web Components: framework-neutral custom elements that render BPMN/DMN determinism analysis",
  "license": "Apache-2.0",
  "author": "Victor França",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francav/dpg-components.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "prepare": "npm run build",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "globals": "^16",
    "jsdom": "^25",
    "prettier": "^3",
    "react": "^19",
    "react-dom": "^19",
    "typescript": "^5.9",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
